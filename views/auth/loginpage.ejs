<%- include('../partials/head') %>
  </head>
  <style>
    @media (max-width: 640px) {
      .login-container {
        width: 90%;
        margin: 1rem auto;
      }
    }
  </style>

  <body class="bg-gradient-to-br from-blue-50 to-blue-100 min-h-screen font-sans">
    <div style="background-color: rgb(9, 66, 86);"><%- include('../partials/nav') %></div>

    <div class="min-h-[calc(100vh-4rem)] flex items-center justify-center p-4">
      <div class="bg-white p-8 rounded-xl shadow-lg w-full max-w-md login-container">
        <div class="text-center mb-8">
          <h1 class="text-2xl font-bold text-gray-800 mb-2">Welcome Back!</h1>
          <p class="text-gray-600">Please login to your account</p>
        </div>

        <form action="/Login" method="POST" class="space-y-6">
          <%- include('../partials/errorInLogin') %>

            <div class="space-y-4">
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input type="text" id="email" name="email" value="<%= oldInput.email ? oldInput.email : '' %>"
                  class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-transparent transition duration-200"
                  placeholder="Username/Email" required />
              </div>

              <div>
                <label for="password" class="block text-sm font-medium text-gray-700 mb-1">
                  Password
                </label>

                <div class="flex items-center ">

                  <input 
                    type="password" 
                    id="password" 
                    name="password"
                    class="w-full px-4 py-2 border border-gray-300 overflow-hidden 
              focus:ring-2 focus:ring-blue-500 focus:border-blue-500 
              transition duration-200" style="border-top-left-radius: 7px; border-bottom-left-radius: 7px;"
                    placeholder="Enter your password" 
                    required 
                  />

                  <button 
                    type="button" 
                    id="togglePassword"
                    class="bg-gray-100 border-l border-gray-300 px-3 h-full flex items-center justify-center hover:bg-gray-200 transition cursor-pointer" style="height: 42px;  background-color: #b8b8b87b; border-top-right-radius: 7px; border-bottom-right-radius: 7px;"
                  >
                  
                    <img
                      id="eyeOpen"
                      src="/images/hidden.png" 
                      alt="Toggle Password"
                      class="h-6 w-6"
                    >
                    <img
                      id="eyeClosed"
                      src="/images/eye.png" 
                      alt="Toggle's Password"
                      class="h-6 w-6 hidden"
                    >
                  </button>

                </div>
              </div>
            </div>

            <button type="submit"
              class="w-full bg-blue-600 text-white py-2 px-4 rounded-lg font-medium hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition duration-200 transform hover:scale-[1.02]">
              Sign In
            </button>

            <div class="text-center mt-4">
              <p class="text-sm text-gray-600">
                Don't have an account?
                <a href="/signup" class="text-blue-600 hover:text-blue-800 font-medium">Sign up</a>
              </p>
            </div>
            <div class="border-t">
              <p class="text-center text-gray-500 text-sm mb-4">Or login with</p>
              <div class="flex justify-center gap-4">
                <a href="/auth/google"
                  class="bg-white border border-gray-300 shadow px-4 py-2 rounded-lg flex items-center space-x-2 hover:shadow-md transition">
                  <img src="/images/search.png" alt="Google" class="w-5 h-5" />
                  <span class="text-sm text-gray-700">Login with Google</span>
                </a>
              </div>
            </div>
        </form>
      </div>
    </div>

    <script>
      const toggleBtn = document.getElementById("togglePassword");
      const passwordInput = document.getElementById("password");

      const eyeOpen = document.getElementById("eyeOpen");
      const eyeClose = document.getElementById("eyeClosed");

      toggleBtn.addEventListener("click", () => {
        if (passwordInput.type === "password") {
          passwordInput.type = "text";

          eyeOpen.classList.add("hidden");
          eyeClose.classList.remove("hidden");
        } else {
          passwordInput.type = "password";

          eyeOpen.classList.remove("hidden");
          eyeClose.classList.add("hidden");
        }
      });
    </script>
  </body>

  </html>